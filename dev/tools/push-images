import argparse
import os
import subprocess

from shared import utils

BUILDER_NAME = "mcp-lifecycle-operator-builder"
IMAGE_NAME = "mcp-lifecycle-operator"


def create_buildx_builder_if_not_exists():
    try:
        subprocess.run(
            ["docker", "buildx", "inspect", BUILDER_NAME],
            check=True,
            capture_output=True,
            text=True,
        )
        print(f"buildx builder '{BUILDER_NAME}' already exists.")
    except subprocess.CalledProcessError:
        print(f"creating buildx builder '{BUILDER_NAME}'.")
        subprocess.run(
            ["docker", "buildx", "create", "--name", BUILDER_NAME], check=True
        )
    subprocess.run(["docker", "buildx", "use", BUILDER_NAME], check=True)


def build_and_push_image(args, image_tag):
    platforms = "linux/amd64,linux/arm64"
    build_cmd = [
        "docker",
        "buildx",
        "build",
        "--progress=plain",
        f"--output=type={args.docker_build_output_type}",
    ]
    if args.docker_build_output_type == "registry":
        build_cmd.append("--platform=" + platforms)

    image_full = utils.get_full_image_name(args, IMAGE_NAME, tag=image_tag)
    build_cmd.extend(["-t", image_full])

    for tag in args.extra_image_tags:
        extra = utils.get_full_image_name(args, IMAGE_NAME, tag=tag)
        build_cmd.extend(["-t", extra])

    build_cmd.extend(["-f", "Dockerfile", "."])
    subprocess.run(build_cmd, check=True)
    print(f"pushed image {image_full}")


def main(args):
    """Builds and pushes the controller Docker image."""
    image_tag = args.image_tag or utils.get_image_tag()

    if not os.path.isfile("Dockerfile"):
        raise FileNotFoundError("Dockerfile not found in repository root")

    print(f"--- Building {IMAGE_NAME} with tag {image_tag}")
    create_buildx_builder_if_not_exists()
    build_and_push_image(args, image_tag)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Build and push Docker images")
    parser.add_argument("--image-prefix",
                        dest="image_prefix",
                        help="Prefix for the image name (requires trailing slash)",
                        type=str,
                        default=os.getenv("IMAGE_PREFIX"))
    parser.add_argument("--extra-image-tag",
                        dest="extra_image_tags",
                        help="Additional tags to apply when publishing images",
                        type=str,
                        action="append",
                        default=[])
    parser.add_argument("--image-tag",
                        dest="image_tag",
                        help="Image tag for this build. Defaults to v{date}-{git_describe}",
                        type=str,
                        default=os.getenv("IMAGE_TAG"))
    parser.add_argument("--local",
                        dest="local",
                        action="store_true",
                        help="Build locally (single platform, no push)")
    args = parser.parse_args()

    if args.local:
        args.docker_build_output_type = "docker"
        if not args.image_prefix:
            args.image_prefix = "localhost/"
    else:
        args.docker_build_output_type = "registry"

    main(args)
